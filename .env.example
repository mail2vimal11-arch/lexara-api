# Anthropic Claude API
CLAUDE_API_KEY=sk-ant-...

# ReceiptsAPI
RECEIPTS_API_KEY=sk_live_...

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/lexrisk

# Redis Cache
REDIS_URL=redis://localhost:6379/0

# Stripe Billing
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# FastAPI.com Deployment
FASTAPI_DEPLOY_KEY=...

# Application Settings
PORT=8000
DEBUG=false
ENVIRONMENT=development
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_ORIGINS=http://localhost:3000,https://lexrisk.com

# Logging
LOG_LEVEL=INFO

# Email (for support notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=noreply@lexrisk.com
SMTP_PASSWORD=...

# ─── LLM Waterfall ─────────────────────────────────────────────────────────────
# Lexara routes contract analysis through a 3-tier waterfall to minimize cost:
#   Tier 1: Groq          (free, fast Llama/Mistral inference)
#   Tier 2: HuggingFace   (fine-tuned SaulLM hosted on HF Inference API)
#   Tier 3: Claude        (paid fallback — always available via CLAUDE_API_KEY)
#
# Each tier requires BOTH a feature flag (USE_*) AND credentials to be active.
# A missing flag silently skips the tier even if the credentials are present,
# so deployments must set the flags explicitly to get the cost savings.

# Tier 1 — Groq (recommended primary tier; free credits, sub-second latency)
# Requires: GROQ_API_KEY. Get one at https://console.groq.com
USE_GROQ=true
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant

# Tier 2 — HuggingFace SaulLM (fine-tuned legal model)
# Requires: HF_API_TOKEN and HF_MODEL_ID.
# HF_MODEL_ID points at the deployed fine-tune (e.g. mail2vimal11-arch/lexara-legal-saullm).
USE_LOCAL_LLM=true
HF_API_TOKEN=hf_...
HF_MODEL_ID=mail2vimal11-arch/lexara-legal-saullm
